# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Para descobrir seu username: publique qualquer prompt no LangSmith Hub, depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
USERNAME_LANGSMITH_HUB=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# Anthropic Configuration
ANTHROPIC_API_KEY=

# LLM Configuration
# Descomente o bloco do provider que deseja usar:

# --- Google Gemini (gratuito, limite 15 req/min) ---
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-flash
# EVAL_MODEL=gemini-2.5-flash

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EVAL_MODEL=gpt-4o

# --- Anthropic Claude (recomendado) ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
EVAL_MODEL=claude-opus-4-7